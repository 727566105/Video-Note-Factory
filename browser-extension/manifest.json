{
  "manifest_version": 3,
  "name": "VideoNote Helper",
  "version": "1.0.0",
  "description": "一键获取平台 Cookie 并快捷提交视频笔记任务到 VideoNote",
  "permissions": ["cookies", "activeTab", "storage", "scripting"],
  "host_permissions": [
    "*://*.bilibili.com/*",
    "*://*.douyin.com/*",
    "*://*.kuaishou.com/*",
    "*://*.youtube.com/*"
  ],
  "optional_host_permissions": [
    "*://*/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "options_page": "options/options.html"
}